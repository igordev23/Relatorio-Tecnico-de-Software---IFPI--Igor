%%{init: {'theme': 'neutral', 'themeVariables': {'lineColor': '#333333', 'primaryTextColor': '#222222', 'primaryColor': '#f4f4f4', 'primaryBorderColor': '#333333', 'secondaryColor': '#ffffff', 'fontSize': '18px', 'fontFamily': 'Arial'}}}%%
classDiagram
    direction TB

    class Pessoa {
      <<abstract>>
      -UUID id
      -String nome
      -String email
      -Boolean ativo
    }
    class Usuario {
      -PerfilEnum perfil
      -DateTime ultimoLogin
      -DateTime horarioPermitidoInicio
      -DateTime horarioPermitidoFim
      +Boolean autenticar(email, senha)
      +Certificado emitirCertificado(participante, template)
    }
    class Participante {
      -String cpf
      -DateTime dataCadastro
      +void vincularCurso(curso)
    }
    class Organizacao {
      -UUID id
      -String nome
      -String cnpj
      -Boolean ativo
      +void adicionarMembro(usuario)
    }
    class Curso {
      -UUID id
      -String nome
      -Integer cargaHoraria
      -Text descricao
      +void inscreverParticipante(participante)
    }
    class ParticipanteCurso {
      -DateTime dataVinculo
    }
    class Template {
      -UUID id
      -String nome
      -TipoArquivoEnum tipoArquivo
      -String caminhoArquivo
      -Integer versao
      -Boolean ativo
      -DateTime dataCriacao
      +void adicionarCampo(campo)
    }
    class CampoDinamico {
      -UUID id
      -String nomeCampo
      -String marcador
      -String tipo
    }
    class AssinaturaDigital {
      -UUID id
      -String imagemAssinatura
      -String hashVerificacao
      -DateTime dataRegistro
    }
    class Certificado {
      -UUID id
      -String codigoUnico
      -DateTime dataEmissao
      -String localEmissao
      -StatusCertificadoEnum status
      -String arquivoPDF
      -String qrCode
      +void gerarPDF()
      +Boolean assinar(assinatura)
      +Boolean enviarEmail(envio)
    }
    class EnvioEmail {
      -UUID id
      -StatusEnvioEnum status
      -Integer tentativas
      -DateTime dataEnvio
      -Text mensagemPersonalizada
      +Boolean enviar()
    }
    class Log {
      <<systemLog>>
      -UUID id
      -String tipo
      -Text descricao
      -DateTime dataHora
      -String ip
    }
    class LogAuditoria {
      <<auditLog>>
      -UUID id
      -String acao
      -DateTime dataHora
      -String local
      +void registrar(usuario)
    }
    class ConfiguracaoSistema {
      -UUID id
      -Boolean envioAutomatico
      -String regraReemissao
      -Text mensagemPadraoEmail
      -Text termosUso
      -Boolean sistemaOnline
      +void aplicar()
    }
    class ChamadoSuporte {
      -UUID id
      -String titulo
      -Text descricao
      -DateTime dataAbertura
      -StatusChamadoEnum status
      -DateTime dataFechamento
      +void abrir(usuario)
      +void fechar()
    }

    class PerfilEnum {
      <<enumeration>>
      ADMIN
      COLABORADOR
    }
    class TipoArquivoEnum {
      <<enumeration>>
      PDF
      HTML
      DOCX
    }
    class StatusCertificadoEnum {
      <<enumeration>>
      EMITIDO
      REVOGADO
      EXPIRADO
    }
    class StatusEnvioEnum {
      <<enumeration>>
      PENDENTE
      ENVIADO
      FALHA
      CANCELADO
    }
    class StatusChamadoEnum {
      <<enumeration>>
      ABERTO
      EM_ANDAMENTO
      FECHADO
      CANCELADO
    }

    %% Interfaces e implementações (embaixo)
    class ICertificateRepository {
      <<interface>>
      +findById(id): Promise<Certificate | null>
      +findByCPFAndCode(cpf, code): Promise<Certificate | null>
      +findAll(): Promise<Certificate[]>
      +create(cert): Promise<Certificate>
      +update(cert): Promise<Certificate>
      +delete(id): Promise<void>
    }
    class ITemplateRepository {
      <<interface>>
      +findById(id): Promise<Template | null>
      +findAll(): Promise<Template[]>
      +create(tpl): Promise<Template>
      +update(tpl): Promise<Template>
      +delete(id): Promise<void>
    }
    class IPDFService {
      <<interface>>
      +generateCertificatePDF(cert, tpl): Promise<Buffer>
    }
    class SupabaseCertificateRepository {
      +findById(id): Promise<Certificate | null>
      +findByCPFAndCode(cpf, code): Promise<Certificate | null>
      +findAll(): Promise<Certificate[]>
      +create(cert): Promise<Certificate>
      +update(cert): Promise<Certificate>
      +delete(id): Promise<void>
    }
    class SupabaseTemplateRepository {
      +findById(id): Promise<Template | null>
      +findAll(): Promise<Template[]>
      +create(tpl): Promise<Template>
      +update(tpl): Promise<Template>
      +delete(id): Promise<void>
    }
    class PDFKitService {
      +generateCertificatePDF(cert, tpl): Promise<Buffer>
    }

    %% Relacionamentos principais (topo)
    Pessoa <|-- Usuario
    Pessoa <|-- Participante

    Organizacao "1" -- "0..*" Usuario
    Organizacao "1" -- "0..*" Participante
    Organizacao "1" -- "0..*" Curso
    Organizacao "1" -- "0..*" Template
    Organizacao "1" -- "0..*" Certificado
    Organizacao "1" -- "1" ConfiguracaoSistema
    Organizacao "1" -- "0..*" ChamadoSuporte

    Participante "1" -- "0..*" ParticipanteCurso
    Curso "1" -- "0..*" ParticipanteCurso
    Template "1" -- "0..*" CampoDinamico
    Template "1" -- "0..1" AssinaturaDigital

    Usuario "1" -- "0..*" Certificado : emitiu
    Usuario "1" -- "0..*" Log
    Usuario "1" -- "0..*" LogAuditoria
    Usuario "1" -- "0..*" ChamadoSuporte : abriu

    Participante "0..*" -- "0..*" Certificado
    Curso "0..*" -- "0..*" Certificado

    Certificado "1" -- "0..1" EnvioEmail
    Certificado "1" -- "1" Template
    Certificado "1" -- "1" AssinaturaDigital : assinadoCom

    %% Dependências de enumerações
    Usuario ..> PerfilEnum : usa
    Template ..> TipoArquivoEnum : usa
    Certificado ..> StatusCertificadoEnum : usa
    EnvioEmail ..> StatusEnvioEnum : usa
    ChamadoSuporte ..> StatusChamadoEnum : usa

    %% Interfaces e realizações (embaixo - fluxo vertical)
    ICertificateRepository <|.. SupabaseCertificateRepository
    ITemplateRepository <|.. SupabaseTemplateRepository
    IPDFService <|.. PDFKitService